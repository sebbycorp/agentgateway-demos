    {
      "id": 1,
      "type": "stat",
      "title": "Avg first-call tool tokens \u2014 STANDARD",
      "description": "All 29 F5 tools sent to the model every call.",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          },
          "decimals": 0
        }
      },
      "targets": [
        {
          "expr": "avg(agw_f5q_first_call_tokens{mode=\"standard\"})"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Avg first-call tool tokens \u2014 SEARCH",
      "description": "Only get_tool + invoke_tool sent; the model discovers tools on demand.",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "decimals": 0
        }
      },
      "targets": [
        {
          "expr": "avg(agw_f5q_first_call_tokens{mode=\"search\"})"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Tool-context reduction (Search vs Standard)",
      "description": "How much smaller the per-call F5 tool context is with Search mode.",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0
        }
      },
      "targets": [
        {
          "expr": "(1 - avg(agw_f5q_first_call_tokens{mode=\"search\"}) / avg(agw_f5q_first_call_tokens{mode=\"standard\"})) * 100"
        }
      ]
