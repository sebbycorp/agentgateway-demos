# Local secrets — GITIGNORED, never commit. Load:  set -a; . .env; set +a
AGENTGATEWAY_LICENSE_KEY=
OPENAI_API_KEY=
# GitHub Personal Access Token — the gateway injects this as a Bearer token to
# GitHub's remote MCP server (api.githubcopilot.com/mcp). The demo only ever hits
# the /mcp/readonly surface, but use a least-privilege (read-only) PAT anyway.
GITHUB_PAT=
