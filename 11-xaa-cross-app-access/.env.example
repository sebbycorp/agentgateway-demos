# Copy to .env (gitignored). Shell exports always win over .env.

# --- Keycloak (Docker) ---
KEYCLOAK_VERSION=26.2
KEYCLOAK_PORT=7080
KEYCLOAK_URL=http://localhost:7080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Lab confidential client (scripts/get-token.sh)
# CLIENT_ID=mcp-lab
# CLIENT_SECRET=mcp-lab-secret

# --- Agentgateway (Phase A) ---
AGW_VERSION=v1.4.0-alpha.1
GATEWAY_URL=http://localhost:3000
GATEWAY_PORT=3000

# --- Sample MCP (todo) ---
MCP_PORT=8000

# Phase C / stretch only
# OPENAI_API_KEY=
# OKTA_DOMAIN=
# OKTA_CLIENT_ID=
