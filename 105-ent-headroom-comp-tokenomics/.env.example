# Local secrets — GITIGNORED, never commit. Load:  set -a; . .env; set +a
AGENTGATEWAY_LICENSE_KEY=
OPENAI_API_KEY=
# GitHub Personal Access Token — the gateway injects this as a Bearer token to
# GitHub's remote MCP server (api.githubcopilot.com/mcp). The demo only ever hits
# the /mcp/readonly surface, but use a least-privilege (read-only) PAT anyway.
# The PAT must be able to READ BOTH repos below.
GITHUB_PAT=

# --- 105 comparison knobs ---------------------------------------------------
# Small repo: the 104 sandbox (apples-to-apples vs 104). Override if you like.
REPO_SMALL=sebbycorp/agw-tokenomics-sandbox
# Large repo: a read-only repo with LOTS of issues/PRs/commits/file contents, so
# Headroom's payload compression has something to bite on. REQUIRED by run_matrix.sh.
REPO_LARGE=

# Headroom proxy launch (run_matrix.sh / test.sh read these). Headroom defaults to
# compression OFF — these force it ON, else the ON column would equal OFF.
HEADROOM_PROXY_COMPRESSION=1
HEADROOM_PROXY_COMPRESSION_MODE=on
HEADROOM_OUTPUT_SHAPER=1
# Upstream the Headroom proxy forwards to (the AGW /openai route, so AGW still traces it):
HEADROOM_PROXY_UPSTREAM=http://localhost:8080/openai
