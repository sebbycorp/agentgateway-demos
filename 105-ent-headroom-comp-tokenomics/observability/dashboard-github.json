    {
      "id": 1,
      "type": "stat",
      "title": "Avg first-call tool tokens \u2014 STANDARD",
      "description": "All 28 read-only GitHub tools sent to the model every call.",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          },
          "decimals": 0
        }
      },
      "targets": [
        {
          "expr": "avg(agw_ghq_first_call_tokens{mode=\"standard\"})"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Avg first-call tool tokens \u2014 SEARCH",
      "description": "Only get_tool + invoke_tool sent; the model discovers tools on demand.",
      "gridPos": {
        "h": 6,
        "w": 8,
